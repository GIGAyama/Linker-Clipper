{
  "manifest_version": 3,
  "name": "GIGA-Linker Clipper",
  "version": "1.0",
  "description": "右クリックで学習サイトをストックし、AIで一括データベース登録します。",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "GIGA-Linkerに一括登録"
  }
}
